,"showDescription":false}},{"id":"fr50JY","key":"stdout","type":"dynamic","valueType":"any","valueDesc":"","label":"stdout","description":""}],"catchError":false},{"nodeId":"yb1JWcs00uT9BnMy","name":"设备表初始化","intro":"根据一定的条件，执行不同的分支。","avatar":"core/workflow/template/ifelse","flowNodeType":"ifElseNode","showStatus":true,"position":{"x":-5409,"y":-540},"inputs":[{"key":"ifElseList","label":"","valueType":"any","renderTypeList":["hidden"],"value":[{"condition":"AND","list":[{"variable":["VARIABLE_NODE_ID","q8ewuEvI"],"condition":"isEmpty","value":"0","valueType":"input"}]}],"debugLabel":"","toolDescription":""}],"outputs":[{"id":"ifElseResult","key":"ifElseResult","type":"static","valueType":"string","valueDesc":"","label":"workflow:judgment_result","description":""}]},{"nodeId":"dqaMJ59ZDTGGxv68","name":"清洗设备表数据","intro":"在沙盒里执行一段脚本代码，可用于进行复杂的数据处理，语法和可用依赖会受到限制。","avatar":"core/workflow/template/codeRun","flowNodeType":"code","showStatus":true,"position":{"x":-3525,"y":-1296},"inputs":[{"key":"system_addInputParam","label":"","valueType":"dynamic","required":false,"customInputConfig":{"selectValueTypeList":["string","number","boolean","object","arrayString","arrayNumber","arrayBoolean","arrayObject","arrayAny","any","chatHistory","datasetQuote","dynamic","selectDataset","selectApp"],"showDescription":false,"showDefaultValue":true},"renderTypeList":["addInputParam"],"debugLabel":"","description":"workflow:these_variables_will_be_input_parameters_for_code_execution","toolDescription":""},{"key":"codeType","label":"","valueType":"string","renderTypeList":["hidden"],"value":"js","debugLabel":"","toolDescription":""},{"key":"code","label":"","valueType":"string","renderTypeList":["custom"],"value":"async function main({ httpRawResponse }) {\n    // 1. 兼容性提取：判断输入是纯字符串还是 FastGPT 的 HTTP 响应对象\n    let stdout = \"\";\n    if (typeof httpRawResponse === \"string\") {\n        stdout = httpRawResponse;\n    } else if (httpRawResponse && typeof httpRawResponse === \"object\") {\n        // 尝试获取不同层级下的 stdout\n        stdout = httpRawResponse.stdout || \n                 httpRawResponse.httpRawResponse?.stdout || \n                 \"\";\n    }\n\n    if (!stdout) return { devicespace: \"\" };\n\n    // 2. 去掉引号的辅助函数\n    const stripQuotes = (v) =>\n      String(v ?? \"\")\n        .trim()\n        .replace(/^\"(.*)\"$/, \"$1\");\n\n    // 3. 解析表格\n    const lines = stdout.split(/\\r?\\n/).map((s) => s.trim());\n    // 仅保留表格内容行：| ... |\n    const tableLines = lines.filter((l) => l.startsWith(\"|\") && l.endsWith(\"|\"));\n    \n    if (tableLines.length < 2) return { devicespace: \"\" };\n\n    // 将行转为数组\n    const rows = tableLines.map(line => \n        line.split(\"|\").slice(1, -1).map(c => stripQuotes(c))\n    );\n\n    const header = rows[0];\n    const nameIdx = header.indexOf(\"Name\");\n    if (nameIdx < 0) return { devicespace: \"\" };\n\n    // 4. 提取数据行并过滤 llmkg_ 前缀\n    const deviceSpaces = rows.slice(1)\n      .map((r) => r[nameIdx])\n      .filter((s) => s && s.startsWith(\"llmkg_\"));\n\n    // 5. 返回结果（按你要求，只要一个字段）\n    // 如果需要数组，直接返回 deviceSpaces；如果需要字符串，用 .join(\",\")\n    return {\n      devicespace: deviceSpaces.join(\",\")\n    };\n}","debugLabel":"","toolDescription":""},{"key":"httpRawResponse","label":"httpRawResponse","valueType":"any","required":true,"customInputConfig":{"selectValueTypeList":["string","number","boolean","object","arrayString","arrayNumber","arrayBoolean","arrayObject","arrayAny","any","chatHistory","datasetQuote","dynamic","selectDataset","selectApp"],"showDescription":false,"showDefaultValue":true},"renderTypeList":["reference"],"value":["jAL1KIZmvZFXbL36","fr50JY"],"canEdit":true}],"outputs":[{"id":"system_rawResponse","key":"system_rawResponse","type":"static","valueType":"object","valueDesc":"","label":"workflow:full_response_data","description":""},{"id":"error","key":"error","type":"error","valueType":"string","valueDesc":"","label":"workflow:error_text","description":""},{"id":"system_addOutputPa
{"_id":{"$oid":"69e5ebb5614a51c203e67b9a"},"parentId":null,"teamId":{"$oid":"69e5d756215f9968f4fab5dc"},"tmbId":{"$oid":"69e5d756215f9968f4fab5de"},"name":"服务器测试","type":"advanced","version":"v2","avatar":"core/app/type/workflowFill","intro":"","modules":[{"nodeId":"userGuide","name":"common:core.module.template.system_config","intro":"common:core.module.template.system_config_info","avatar":"core/workflow/template/systemConfig","flowNodeType":"userGuide","position":{"x":-5235,"y":-1620},"version":"481","inputs":[{"key":"welcomeText","label":"core.app.Welcome Text","valueType":"string","renderTypeList":["hidden"],"value":""},{"key":"variables","label":"core.app.Chat Variable","valueType":"any","renderTypeList":["hidden"],"value":[]},{"key":"questionGuide","label":"core.app.Question Guide","valueType":"any","renderTypeList":["hidden"],"value":{"open":false}},{"key":"tts","label":"","valueType":"any","renderTypeList":["hidden"],"value":{"type":"web"}},{"key":"whisper","label":"","valueType":"any","renderTypeList":["hidden"],"value":{"open":false,"autoSend":false,"autoTTSResponse":false}},{"key":"scheduleTrigger","label":"","valueType":"any","renderTypeList":["hidden"],"value":null}],"outputs":[]},{"nodeId":"448745","name":"common:core.module.template.work_start","intro":"","avatar":"core/workflow/template/workflowStart","flowNodeType":"workflowStart","position":{"x":-5835,"y":-647},"version":"481","inputs":[{"key":"userChatInput","label":"workflow:user_question","valueType":"string","required":true,"renderTypeList":["reference","textarea"],"debugLabel":"","toolDescription":"用户问题"}],"outputs":[{"id":"userChatInput","key":"userChatInput","type":"static","valueType":"string","label":"common:core.module.input.label.user question","description":""}]},{"nodeId":"bEGyTijQYXiijgkL","name":"故障类型分析","intro":"可从文本中提取指定的数据，例如：sql语句、搜索关键词、代码等","avatar":"core/workflow/template/extractJson","flowNodeType":"contentExtract","showStatus":true,"position":{"x":-15,"y":-801},"version":"4.9.2","inputs":[{"key":"model","label":"common:core.module.input.label.aiModel","valueType":"string","required":true,"renderTypeList":["selectLLMModel","reference"],"value":"Pro/deepseek-ai/DeepSeek-V3.2","debugLabel":"","toolDescription":""},{"key":"description","label":"workflow:extraction_requirements_description","valueType":"string","placeholder":"workflow:extraction_requirements_placeholder","renderTypeList":["textarea","reference"],"value":" 你的任务：根据用户输入，在已知的一级/二级故障目录中，匹配“最恰当的一个二级故障名称”。\n\n  已知目录：\n  {{$gMBZtrBTbpDPI3Ob.qLUQfhG0ILRX$}}\n\n  规则：\n 输出要求：\n  只输出一个 JSON 对象，且只能有这个键：\n  {\"故障二级节点\":\"已知目录中的一个二级故障\"}\n\n  现在开始匹配并输出结果。","debugLabel":"","description":"workflow:extraction_requirements_description_detail","toolDescription":""},{"key":"history","label":"common:core.module.input.label.chat history","valueType":"chatHistory","required":true,"max":50,"min":0,"renderTypeList":["numberInput","reference"],"value":0,"debugLabel":"","description":"workflow:max_dialog_rounds","toolDescription":""},{"key":"content","label":"workflow:text_to_extract","valueType":"string","required":true,"renderTypeList":["reference","textarea"],"value":["448745","userChatInput"],"debugLabel":"","toolDescription":"需要检索的内容"},{"key":"extractKeys","label":"","valueType":"any","renderTypeList":["custom"],"value":[{"valueType":"string","required":true,"defaultValue":"","desc":"用户问题对应的故障二级节点","key":"故障二级节点","enum":""}],"debugLabel":"","description":"workflow:target_fields_description","toolDescription":""}],"outputs":[{"id":"success","key":"success","type":"static","valueType":"boolean","valueDesc":"","label":"workflow:full_field_extraction","description":"提取字段全部填充时返回 true （模型提取或使用默认值均属于成功）","required":true},{"id":"fields","key":"fields","type":"static","valueType":"string","valueDesc":"","label":"workflow:complete_extraction_result","description":"一个 JSON 字符串，例如：{\"name:\":\"YY\",\"Time\":\"2023/7/2 18:00\"}","required":true},{"id":"system_error_text","key":"system_error_text","type":"error","valueType":"string","valueDesc":"","label":"workflow:error_text","description":""},{"id":"iolSes0holAfPADB","key":"故障二级节点","type":"static","valueType":"string","label":"提取结果-故障二级节点"}],"catchError":false},{"nodeId":"fFpXpftMQrWMSyQb","name":"基础数据获取","intro":"可以发出一个 HTTP 请求，实现更为复杂的操作（联网搜索、数据库查询等）","avatar":"core/workflow/template/httpRequest","flowNodeType":"httpRequest468","showStatus":true,"position":{"x":-1665,"y":-785},"inputs":[{"key":"system_addInputParam","label":"","valueType":"dynamic","required":false,"customInputConfig":{"selectValueTypeList":["string","number","boolean","object","arrayString","arrayNumber","arrayBoolean","arrayObject","arrayAny","any","chatHistory","datasetQuote","dynamic","selectDataset","selectApp"],"showDescription":false,"showDefaultValue":true},"renderTypeList":["addInputParam"],"debugLabel":"","description":"common:core.module.input.description.HTTP Dynamic Input","toolDescription":"","deprecated":false},{"key":"system_httpMethod","label":"","valueType":"string","required":true,"renderTypeList":["custom"],"value":"POST","debugLabel":"","toolDescription":""},{"key":"system_httpTimeout","label":"","valueType":"number","required":true,"max":600,"min":5,"renderTypeList":["custom"],"value":30,"debugLabel":"","toolDescription":""},{"key":"system_httpReqUrl","label":"","valueType":"string","required":false,"placeholder":"https://api.ai.com/getInventory","renderTypeList":["hidden"],"value":"http://nebula-http-gateway:8787/graph/query","debugLabel":"","description":"common:core.module.input.description.Http Request Url","toolDescription":""},{"key":"system_header_secret","label":"","valueType":"object","required":false,"renderTypeList":["hidden"],"debugLabel":"","toolDescription":""},{"key":"system_httpHeader","label":"","valueType":"any","required":false,"placeholder":"common:core.module.input.description.Http Request Header","renderTypeList":["custom"],"value":[],"debugLabel":"","description":"common:core.module.input.description.Http Request Header","toolDescription":""},{"key":"system_httpParams","label":"","valueType":"any","required":false,"renderTypeList":["hidden"],"value":[],"debugLabel":"","toolDescription":""},{"key":"system_httpJsonBody","label":"","valueType":"any","required":false,"renderTypeList":["hidden"],"value":"{\n  \"space\": \"{{$hJmYZWKFOW26n5E1.nFdHUxLCQ0jpMHOd$}}\",\n  \"ngql\": \"MATCH (l1:fault_l1)-[:contains]->(l2:fault_l2) RETURN l1.fault_l1.source_id AS l1_source_id, l1.fault_l1.name AS l1_name, l2.fault_l2.source_id AS l2_source_id, l2.fault_l2.name AS l2_name ORDER BY l1_source_id, l2_source_id;\"\n}","debugLabel":"","toolDescription":""},{"key":"system_httpFormBody","label":"","valueType":"any","required":false,"renderTypeList":["hidden"],"value":[],"debugLabel":"","toolDescription":""},{"key":"system_httpContentType","label":"","valueType":"string","required":false,"renderTypeList":["hidden"],"value":"json","debugLabel":"","toolDescription":""}],"outputs":[{"id":"httpRawResponse","key":"httpRawResponse","type":"static","valueType":"any","valueDesc":"","label":"workflow:raw_response","description":"HTTP请求的原始响应。只能接受字符串或JSON类型响应数据。","required":true},{"id":"error","key":"error","type":"error","valueType":"string","valueDesc":"","label":"workflow:error_text","description":""},{"id":"system_addOutputParam","key":"system_addOutputParam","type":"dynamic","valueType":"dynamic","valueDesc":"","label":"输出字段提取","description":"可以通过 JSONPath 语法来提取响应值中的指定字段","customFieldConfig":{"selectValueTypeList":["string","number","boolean","object","arrayString","arrayNumber","arrayBoolean","arrayObject","arrayAny","any","chatHistory","datasetQuote","dynamic","selectDataset","selectApp"],"showDefaultValue":false,"showDescription":false}}],"catchError":false},{"nodeId":"gMBZtrBTbpDPI3Ob","name":"基础数据清洗","intro":"在沙盒里执行一段脚本代码，可用于进行复杂的数据处理，语法和可用依赖会受到限制。","avatar":"core/workflow/template/codeRun","flowNodeType":"code","showStatus":true,"position":{"x":-885,"y":-678},"inputs":[{"key":"system_addInputParam","label":"","valueType":"dynamic","required":false,"customInputConfig":{"selectValueTypeList":["string","number","boolean","object","arrayString","arrayNumber","arrayBoolean","arrayObject","arrayAny","any","chatHistory","datasetQuote","dynamic","selectDataset","selectApp"],"showDescription":false,"showDefaultValue":true},"renderTypeList":["addInputParam"],"debugLabel":"","description":"workflow:these_variables_will_be_input_parameters_for_code_execution","toolDescription":""},{"key":"codeType","label":"","valueType":"string","renderTypeList":["hidden"],"value":"js","debugLabel":"","toolDescription":""},{"key":"code","label":"","valueType":"string","renderTypeList":["custom"],"value":" async function main({ httpRawResponse }) {\n    const raw =\n      httpRawResponse &&\n      typeof httpRawResponse === \"object\" &&\n      httpRawResponse.httpRawResponse &&\n      typeof httpRawResponse.httpRawResponse === \"object\"\n        ? httpRawResponse.httpRawResponse\n        : httpRawResponse;\n\n    const stdout = typeof raw?.stdout === \"string\" ? raw.stdout : \"\";\n    if (!stdout) {\n      return { summary_text: \"没有可解析的查询结果。\" };\n    }\n\n    const stripQuotes = (v) =>\n      String(v ?? \"\")\n        .trim()\n        .replace(/^\"(.*)\"$/, \"$1\");\n\n    const parseTableRow = (line) =>\n      line\n        .split(\"|\")\n        .slice(1, -1)\n        .map((c) => stripQuotes(c.trim()));\n\n    const lines = stdout.split(/\\r?\\n/).map((s) => s.trim());\n    const tableLines = lines.filter((l) => l.startsWith(\"|\") && l.endsWith(\"|\"));\n\n    const rows = [];\n    for (const line of tableLines) {\n      const cells = parseTableRow(line);\n      if (cells.length < 4) continue;\n      if (cells[0] === \"l1_source_id\" && cells[1] === \"l1_name\") continue;\n      if (!/^\\d+$/.test(cells[0]) || !/^\\d+$/.test(cells[2])) continue;\n\n      rows.push({\n        l1_source_id: Number(cells[0]),\n        l1_name: cells[1],\n        l2_source_id: Number(cells[2]),\n        l2_name: cells[3]\n      });\n    }\n\n    if (rows.length === 0) {\n      return { summary_text: \"未解析到一级/二级故障映射数据。\" };\n    }\n\n    const l1Map = new Map();\n    for (const r of rows) {\n      const key = String(r.l1_source_id);\n      if (!l1Map.has(key)) {\n        l1Map.set(key, {\n          l1_source_id: r.l1_source_id,\n          l1_name: r.l1_name,\n          l2Map: new Map()\n        });\n      }\n      l1Map.get(key).l2Map.set(String(r.l2_source_id), r.l2_name);\n    }\n\n    const l1List = Array.from(l1Map.values())\n      .sort((a, b) => a.l1_source_id - b.l1_source_id)\n      .map((item) => {\n        const l2Names = Array.from(item.l2Map.values());\n        return {\n          l1_name: item.l1_name,\n          l2_count: l2Names.length,\n          l2_names: l2Names\n        };\n      });\n\n    const l1Names = l1List.map((x) => x.l1_name);\n    const total = l1List.reduce((s, x) => s + x.l2_count, 0);\n    const detail = l1List\n      .map((x) => `${x.l1_name}有${x.l2_count}个二级故障：${x.l2_names.join(\"、\")}`)\n      .join(\"；\");\n\n    const summary_text =\n      `一级故障有：${l1Names.join(\"、\")}。` +\n      `\\n其中：${detail}。` +\n      `\\n合计二级故障映射${total}条。`;\n\n    return { summary_text };\n  }","debugLabel":"","toolDescription":""},{"key":"httpRawResponse","label":"httpRawResponse","valueType":"any","required":true,"customInputConfig":{"selectValueTypeList":["string","number","boolean","object","arrayString","arrayNumber","arrayBoolean","arrayObject","arrayAny","any","chatHistory","datasetQuote","dynamic","selectDataset","selectApp"],"showDescription":false,"showDefaultValue":true},"renderTypeList":["reference"],"value":["fFpXpftMQrWMSyQb","httpRawResponse"],"canEdit":true}],"outputs":[{"id":"system_rawResponse","key":"system_rawResponse","type":"static","valueType":"object","valueDesc":"","label":"workflow:full_response_data","description":""},{"id":"error","key":"error","type":"error","valueType":"string","valueDesc":"","label":"workflow:error_text","description":""},{"id":"system_addOutputParam","key":"system_addOutputParam","type":"dynamic","valueType":"dynamic","valueDesc":"","label":"","description":"将代码中 return 的对象作为输出，传递给后续的节点。变量名需要对应 return 的 key","customFieldConfig":{"selectValueTypeList":["string","number","boolean","object","arrayString","arrayNumber","arrayBoolean","arrayObject","arrayAny","any","chatHistory","datasetQuote","dynamic","selectDataset","selectApp"],"showDefaultValue":false,"showDescription":false}},{"id":"qLUQfhG0ILRX","key":"summary_text","type":"dynamic","valueType":"string","valueDesc":"","label":"summary_text","description":""}],"catchError":false},{"nodeId":"rpJznDcYzR74Wijw","name":"下游节点获取","intro":"可以发出一个 HTTP 请求，实现更为复杂的操作（联网搜索、数据库查询等）","avatar":"core/workflow/template/httpRequest","flowNodeType":"httpRequest468","showStatus":true,"position":{"x":810,"y":-785},"inputs":[{"key":"system_addInputParam","label":"","valueType":"dynamic","required":false,"customInputConfig":{"selectValueTypeList":["string","number","boolean","object","arrayString","arrayNumber","arrayBoolean","arrayObject","arrayAny","any","chatHistory","datasetQuote","dynamic","selectDataset","selectApp"],"showDescription":false,"showDefaultValue":true},"renderTypeList":["addInputParam"],"debugLabel":"","description":"common:core.module.input.description.HTTP Dynamic Input","toolDescription":"","deprecated":false},{"key":"system_httpMethod","label":"","valueType":"string","required":true,"renderTypeList":["custom"],"value":"POST","debugLabel":"","toolDescription":""},{"key":"system_httpTimeout","label":"","valueType":"number","required":true,"max":600,"min":5,"renderTypeList":["custom"],"value":30,"debugLabel":"","toolDescription":""},{"key":"system_httpReqUrl","label":"","valueType":"string","required":false,"placeholder":"https://api.ai.com/getInventory","renderTypeList":["hidden"],"value":"http://nebula-http-gateway:8787/graph/query","debugLabel":"","description":"common:core.module.input.description.Http Request Url","toolDescription":""},{"key":"system_header_secret","label":"","valueType":"object","required":false,"renderTypeList":["hidden"],"debugLabel":"","toolDescription":""},{"key":"system_httpHeader","label":"","valueType":"any","required":false,"placeholder":"common:core.module.input.description.Http Request Header","renderTypeList":["custom"],"value":[],"debugLabel":"","description":"common:core.module.input.description.Http Request Header","toolDescription":""},{"key":"system_httpParams","label":"","valueType":"any","required":false,"renderTypeList":["hidden"],"value":[],"debugLabel":"","toolDescription":""},{"key":"system_httpJsonBody","label":"","valueType":"any","required":false,"renderTypeList":["hidden"],"value":"{\n  \"space\": \"{{$hJmYZWKFOW26n5E1.nFdHUxLCQ0jpMHOd$}}\",\n  \"ngql\": \"MATCH (f:entity) WHERE f.entity.lvl == 2 AND f.entity.name == '{{$bEGyTijQYXiijgkL.iolSes0holAfPADB$}}' OPTIONAL MATCH (f)-[:caused_by]->(c:fault_cause) RETURN 3 AS lvl, c.fault_cause.name AS name, c.fault_cause.node_desc AS node_desc UNION ALL MATCH (f:entity) WHERE f.entity.lvl == 2 AND f.entity.name == '{{$bEGyTijQYXiijgkL.iolSes0holAfPADB$}}' OPTIONAL MATCH (f)-[:caused_by]->(:fault_cause)-[:has_symptom]->(s:fault_symptom) RETURN 4 AS lvl, s.fault_symptom.name AS name, s.fault_symptom.node_desc AS node_desc UNION ALL MATCH (f:entity) WHERE f.entity.lvl == 2 AND f.entity.name == '{{$bEGyTijQYXiijgkL.iolSes0holAfPADB$}}' OPTIONAL MATCH (f)-[:handled_by]->(m:response_measure) RETURN 3 AS lvl, m.response_measure.name AS name, m.response_measure.node_desc AS node_desc UNION ALL MATCH (f:entity) WHERE f.entity.lvl == 2 AND f.entity.name == '{{$bEGyTijQYXiijgkL.iolSes0holAfPADB$}}' OPTIONAL MATCH (f)-[:caused_by]->(:fault_cause)-[:results_in]->(co:fault_consequence) RETURN 4 AS lvl, co.fault_consequence.name AS name, co.fault_consequence.node_desc AS node_desc UNION ALL MATCH (f:entity) WHERE f.entity.lvl == 2 AND f.entity.name == '{{$bEGyTijQYXiijgkL.iolSes0holAfPADB$}}' OPTIONAL MATCH (f)-[:handled_by]->(:response_measure)-[:has_risk]->(r:safety_risk) RETURN 4 AS lvl, r.safety_risk.name AS name, r.safety_risk.node_desc AS node_desc UNION ALL MATCH (f:entity) WHERE f.entity.lvl == 2 AND f.entity.name == '{{$bEGyTijQYXiijgkL.iolSes0holAfPADB$}}' OPTIONAL MATCH (f)-[:handled_by]->(:response_measure)-[:needs_resource]->(er:emergency_resource) RETURN 4 AS lvl, er.emergency_resource.name AS name, er.emergency_resource.node_desc AS node_desc;\"\n}","debugLabel":"","toolDescription":""},{"key":"system_httpFormBody","label":"","valueType":"any","required":false,"renderTypeList":["hidden"],"value":[],"debugLabel":"","toolDescription":""},{"key":"system_httpContentType","label":"","valueType":"string","required":false,"renderTypeList":["hidden"],"value":"json","debugLabel":"","toolDescription":""}],"outputs":[{"id":"httpRawResponse","key":"httpRawResponse","type":"static","valueType":"any","valueDesc":"","label":"workflow:raw_response","description":"HTTP请求的原始响应。只能接受字符串或JSON类型响应数据。","required":true},{"id":"error","key":"error","type":"error","valueType":"string","valueDesc":"","label":"workflow:error_text","description":""},{"id":"system_addOutputParam","key":"system_addOutputParam","type":"dynamic","valueType":"dynamic","valueDesc":"","label":"输出字段提取","description":"可以通过 JSONPath 语法来提取响应值中的指定字段","customFieldConfig":{"selectValueTypeList":["string","number","boolean","object","arrayString","arrayNumber","arrayBoolean","arrayObject","arrayAny","any","chatHistory","datasetQuote","dynamic","selectDataset","selectApp"],"showDefaultValue":false,"showDescription":false}}],"catchError":false},{"nodeId":"fmRLeRT0lvkngtJQ","name":"下游节点数据清洗","intro":"在沙盒里执行一段脚本代码，可用于进行复杂的数据处理，语法和可用依赖会受到限制。","avatar":"core/workflow/template/codeRun","flowNodeType":"code","showStatus":true,"position":{"x":1605,"y":-678},"inputs":[{"key":"system_addInputParam","label":"","valueType":"dynamic","required":false,"customInputConfig":{"selectValueTypeList":["string","number","boolean","object","arrayString","arrayNumber","arrayBoolean","arrayObject","arrayAny","any","chatHistory","datasetQuote","dynamic","selectDataset","selectApp"],"showDescription":false,"showDefaultValue":true},"renderTypeList":["addInputParam"],"debugLabel":"","description":"workflow:these_variables_will_be_input_parameters_for_code_execution","toolDescription":""},{"key":"codeType","label":"","valueType":"string","renderTypeList":["hidden"],"value":"js","debugLabel":"","toolDescription":""},{"key":"code","label":"","valueType":"string","renderTypeList":["custom"],"value":"async function main({ httpRawResponse }) {\n    // 1. 兼容多种响应结构，提取 stdout\n    const raw =\n      httpRawResponse &&\n      typeof httpRawResponse === \"object\" &&\n      httpRawResponse.httpRawResponse &&\n      typeof httpRawResponse.httpRawResponse === \"object\"\n        ? httpRawResponse.httpRawResponse\n        : httpRawResponse;\n\n    const stdout = typeof raw?.stdout === \"string\" ? raw.stdout : \"\";\n\n    // 2. 默认兜底文案（修复了原代码中字符串跨行导致的 Unexpected EOF 报错）\n    const fallback = \"当前二级故障：未知。故障原因：未检索到。应对措施：未检索到。故障现象：未检索到。故障后果：未检索到。安全风险：未检索到。应急资源：未检索到。\";\n\n    if (!stdout || !stdout.includes(\"|\")) {\n      return { result: fallback };\n    }\n\n    // 3. 辅助函数：去除引号和空格\n    function stripQuotes(v) {\n      return String(v == null ? \"\" : v).trim().replace(/^\"(.*)\"$/, \"$1\");\n    }\n\n    // 4. 解析表格行\n    function parseRow(line) {\n      return line\n        .split(\"|\")\n        .slice(1, -1)\n        .map(function (c) {\n          return stripQuotes(c.trim());\n        });\n    }\n\n    const lines = stdout.split(/\\r?\\n/).map(function (s) {\n      return s.trim();\n    });\n    \n    // 过滤出真正的表格行（跳过 ASCII 分隔线）\n    const tableLines = lines.filter(function (l) {\n      return l.startsWith(\"|\") && l.endsWith(\"|\") && !l.includes(\"+--\");\n    });\n\n    if (tableLines.length < 2) {\n      return { result: fallback };\n    }\n\n    const rows = tableLines.map(parseRow);\n    const header = rows[0];\n    const body = rows.slice(1);\n\n    // 5. 定位列索引（对应你 nGQL 中的 AS name 和 AS node_desc）\n    const idxName = header.indexOf(\"name\");\n    const idxNodeDesc = header.indexOf(\"node_desc\");\n\n    if (idxName < 0) {\n      return { result: fallback };\n    }\n\n    // 6. 初始化分类容器\n    const reason = [];\n    const measure = [];\n    const symptom = [];\n    const consequence = [];\n    const risk = [];\n    const resource = [];\n    const other = [];\n\n    let faultName = \"\";\n\n    // 7. 遍历数据并分类\n    body.forEach(function (r) {\n      const name = (r[idxName] || \"\").trim();\n      const desc = idxNodeDesc >= 0 ? (r[idxNodeDesc] || \"\").trim() : \"\";\n\n      if (!name) return;\n\n      // 自动提取故障主体名称（取第一个关联节点的名称前缀）\n      if (!faultName) {\n        faultName = name.split('-')[0];\n      }\n\n      const item = desc ? (name + \"：\" + desc) : name;\n\n      // 根据业务关键词分类\n      if (name.indexOf(\"故障原因\") >= 0) reason.push(item);\n      else if (name.indexOf(\"应对措施\") >= 0) measure.push(item);\n      else if (name.indexOf(\"故障现象\") >= 0) symptom.push(item);\n      else if (name.indexOf(\"故障后果\") >= 0) consequence.push(item);\n      else if (name.indexOf(\"安全风险\") >= 0) risk.push(item);\n      else if (name.indexOf(\"应急资源\") >= 0) resource.push(item);\n      else other.push(item);\n    });\n\n    // 格式化辅助函数\n    function fmt(arr, emptyText) {\n      return arr.length > 0 ? arr.join(\"；\") : emptyText;\n    }\n\n    // 8. 组装最终结果\n    const result =\n      \"当前二级故障：\" + (faultName || \"未知\") + \"。\" +\n      \"故障原因：\" + fmt(reason, \"未检索到\") + \"。\" +\n      \"应对措施：\" + fmt(measure, \"未检索到\") + \"。\" +\n      \"故障现象：\" + fmt(symptom, \"未检索到\") + \"。\" +\n      \"故障后果：\" + fmt(consequence, \"未检索到\") + \"。\" +\n      \"安全风险：\" + fmt(risk, \"未检索到\") + \"。\" +\n      \"应急资源：\" + fmt(resource, \"未检索到\") + \"。\" +\n      \"其他相关节点：\" + fmt(other, \"无\") + \"。\";\n\n    return { result: result };\n}","debugLabel":"","toolDescription":""},{"key":"httpRawResponse","label":"httpRawResponse","valueType":"any","required":true,"customInputConfig":{"selectValueTypeList":["string","number","boolean","object","arrayString","arrayNumber","arrayBoolean","arrayObject","arrayAny","any","chatHistory","datasetQuote","dynamic","selectDataset","selectApp"],"showDescription":false,"showDefaultValue":true},"renderTypeList":["reference"],"value":["rpJznDcYzR74Wijw","httpRawResponse"],"canEdit":true}],"outputs":[{"id":"system_rawResponse","key":"system_rawResponse","type":"static","valueType":"object","valueDesc":"","label":"workflow:full_response_data","description":""},{"id":"error","key":"error","type":"error","valueType":"string","valueDesc":"","label":"workflow:error_text","description":""},{"id":"system_addOutputParam","key":"system_addOutputParam","type":"dynamic","valueType":"dynamic","valueDesc":"","label":"","description":"将代码中 return 的对象作为输出，传递给后续的节点。变量名需要对应 return 的 key","customFieldConfig":{"selectValueTypeList":["string","number","boolean","object","arrayString","arrayNumber","arrayBoolean","arrayObject","arrayAny","any","chatHistory","datasetQuote","dynamic","selectDataset","selectApp"],"showDefaultValue":false,"showDescription":false}},{"id":"qLUQfhG0ILRX","key":"result","type":"dynamic","valueType":"string","valueDesc":"","label":"result","description":""}],"catchError":false},{"nodeId":"j5U22AiVe7XSNPFG","name":"最终生成","intro":"AI 大模型对话","avatar":"core/workflow/template/aiChat","flowNodeType":"chatNode","showStatus":true,"position":{"x":2400,"y":-829.5},"version":"4.9.7","inputs":[{"key":"model","label":"common:core.module.input.label.aiModel","valueType":"string","renderTypeList":["settingLLMModel","reference"],"debugLabel":"","toolDescription":""},{"key":"temperature","label":"","valueType":"number","renderTypeList":["hidden"],"debugLabel":"","toolDescription":""},{"key":"maxToken","label":"","valueType":"number","renderTypeList":["hidden"],"debugLabel":"","toolDescription":""},{"key":"isResponseAnswerText","lab
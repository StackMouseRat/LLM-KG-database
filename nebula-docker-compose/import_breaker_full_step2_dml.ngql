USE llmkg_test;
INSERT VERTEX entity(name, node_desc, lvl, source_id, degree, weight, stroke) VALUES "n_0":("高压断路器","依据第一至第七层级汇总稿形成的高压断路器故障知识图谱实体。",0,0,7,10,"#9A3412"), "n_1":("灭弧与介质状态故障","高压断路器故障一级大类：灭弧与介质状态故障。",1,1,5,9,"#D97706"), "n_2":("导电回路与开断故障","高压断路器故障一级大类：导电回路与开断故障。",1,2,4,9,"#0EA5E9"), "n_3":("合分闸操作故障","高压断路器故障一级大类：合分闸操作故障。",1,3,3,9,"#8B5CF6"), "n_4":("操动机构与机械传动故障","高压断路器故障一级大类：操动机构与机械传动故障。",1,4,8,9,"#10B981"), "n_5":("操作能源与控制回路故障","高压断路器故障一级大类：操作能源与控制回路故障。",1,5,9,9,"#EF4444"), "n_6":("继电保护与测量二次回路故障","高压断路器故障一级大类：继电保护与测量二次回路故障。",1,6,6,9,"#6366F1"), "n_7":("本体绝缘与支撑结构故障","高压断路器故障一级大类：本体绝缘与支撑结构故障。",1,7,6,9,"#14B8A6"), "n_8":("油断路器缺油故障","灭弧与介质状态故障下的二级故障小类：油断路器缺油故障。",2,8,3,8,"#D97706"), "n_9":("油断路器缺油故障-故障原因","灭弧室或油路漏油、渗油，导致油位持续下降并严重缺油。",3,9,3,6,"#FA8C16"), "n_10":("油断路器缺油故障-故障现象","油位计中看不见油面，伴随明显漏油，断路器开断安全性下降。",4,10,1,6,"#1890FF"), "n_11":("油断路器缺油故障-应对措施","查明漏油部位，必要时停运处理，采取可靠安全措施补油和检修，严禁严重缺油运行。",3,11,3,6,"#52C41A"), "n_12":("油断路器缺油故障-故障后果","灭弧和开断能力下降，可能导致设备损坏、停运和事故扩大。",4,12,1,6,"#E8684A"), "n_13":("油断路器缺油故障-安全风险","处置中存在触电、电弧灼伤、油介质着火和误操作停电风险。",4,13,1,6,"#722ED1"), "n_14":("空气断路器气压降低故障","灭弧与介质状态故障下的二级故障小类：空气断路器气压降低故障。",2,14,3,8,"#D97706"), "n_15":("空气断路器气压降低故障-故障原因","运行气压低于最小允许值，可能与供气不足、气路泄漏或相关部件异常有关。",3,15,3,6,"#FA8C16"), "n_16":("空气断路器气压降低故障-故障现象","压力信号触发，操作回路被切断或重合闸被闭锁，断路器运行能力下降。",4,16,1,6,"#1890FF"), "n_17":("空气断路器气压降低故障-应对措施","迅速检查压力下降原因，利用气压降低接点切断操作回路或停止重合闸，必要时停运处理。",3,17,3,6,"#52C41A");
INSERT VERTEX entity(name, node_desc, lvl, source_id, degree, weight, stroke) VALUES "n_18":("空气断路器气压降低故障-故障后果","断路器无法可靠执行分合闸操作，影响供电可靠性和故障处置能力。",4,18,1,6,"#E8684A"), "n_19":("空气断路器气压降低故障-安全风险","存在带压系统突然释放、误动作、触电和停电切换风险。",4,19,1,6,"#722ED1"), "n_20":("六氟化硫介质泄漏故障","灭弧与介质状态故障下的二级故障小类：六氟化硫介质泄漏故障。",2,20,3,8,"#D97706"), "n_21":("六氟化硫介质泄漏故障-故障原因","气室、密封部位或连接部位漏气，导致气体压力下降并触发报警。",3,21,3,6,"#FA8C16"), "n_22":("六氟化硫介质泄漏故障-故障现象","表压下降、漏气报警、可检出漏点，严重时大量漏气并伴随气体外逸。",4,22,1,6,"#1890FF"), "n_23":("六氟化硫介质泄漏故障-应对措施","检查压力表，使用检漏仪查找漏点并补气；大量漏气时停电处理并加强现场防护和通风。",3,23,3,6,"#52C41A"), "n_24":("六氟化硫介质泄漏故障-故障后果","绝缘和灭弧性能下降，断路器被迫停运或限运，并带来人员暴露风险。",4,24,1,6,"#E8684A"), "n_25":("六氟化硫介质泄漏故障-安全风险","存在有害气体暴露、缺氧、触电、电弧灼伤和防护不到位风险。",4,25,1,6,"#722ED1"), "n_26":("灭弧室烧损爆炸故障","灭弧与介质状态故障下的二级故障小类：灭弧室烧损爆炸故障。",2,26,3,8,"#D97706"), "n_27":("灭弧室烧损爆炸故障-故障原因","短路电流超过开断能力、系统短路电流控制不当、灭弧室油位过低或缺油、开断故障后喷油严重未及时处理。",3,27,3,6,"#FA8C16"), "n_28":("灭弧室烧损爆炸故障-故障现象","灭弧室烧损、喷油严重、绝缘和灭弧性能急剧下降，严重时爆炸。",4,28,1,6,"#1890FF"), "n_29":("灭弧室烧损爆炸故障-应对措施","定期核算短路电流，采取限流与保护优化措施，对能力不足设备及时调换升级，并加强油位监视和状态检修。",3,29,3,6,"#52C41A"), "n_30":("灭弧室烧损爆炸故障-故障后果","设备严重损坏甚至报废，停电范围扩大，并伴随事故升级风险。",4,30,1,6,"#E8684A"), "n_31":("灭弧室烧损爆炸故障-安全风险","存在爆炸、飞溅、火灾、电弧灼伤和人身伤害风险。",4,31,1,6,"#722ED1"), "n_32":("断路故障","导电回路与开断故障下的二级故障小类：断路故障。",2,32,3,8,"#0EA5E9"), "n_33":("断路故障-故障原因","连接件、触头、导电夹等导电部位接触失效、松动断裂或材质强度不足。",3,33,3,6,"#FA8C16"), "n_34":("断路故障-故障现象","电流通路中断，设备无法正常送电或运行中突然失去导通能力。",4,34,1,6,"#1890FF"), "n_35":("断路故障-应对措施","检查断点、连接件和触头状态，对失效和损伤部件及时更换和紧固。",3,35,3,6,"#52C41A");
INSERT VERTEX entity(name, node_desc, lvl, source_id, degree, weight, stroke) VALUES "n_36":("断路故障-故障后果","直接造成停电、运行中断或设备功能失效。",4,36,1,6,"#E8684A"), "n_37":("断路故障-安全风险","排查断点和恢复送电过程中存在误送电、触电和电弧灼伤风险。",4,37,1,6,"#722ED1"), "n_38":("导电回路直阻超标故障","导电回路与开断故障下的二级故障小类：导电回路直阻超标故障。",2,38,3,8,"#0EA5E9"), "n_39":("导电回路直阻超标故障-故障原因","接触面氧化、固定螺钉松动、接触压力不足或接触不良。",3,39,3,6,"#FA8C16"), "n_40":("导电回路直阻超标故障-故障现象","导电回路直阻测量值超标，接触部位发热增加。",4,40,1,6,"#1890FF"), "n_41":("导电回路直阻超标故障-应对措施","检查真空泡上部接触面和导电夹固定螺钉，必要时除氧化、紧固并复测。",3,41,3,6,"#52C41A"), "n_42":("导电回路直阻超标故障-故障后果","接触发热加剧，长期会加速触头损伤，严重时设备烧损停运。",4,42,1,6,"#E8684A"), "n_43":("导电回路直阻超标故障-安全风险","存在烫伤、触电、电弧灼伤和恢复不当后二次过热风险。",4,43,1,6,"#722ED1"), "n_44":("触头及导电连接异常故障","导电回路与开断故障下的二级故障小类：触头及导电连接异常故障。",2,44,3,8,"#0EA5E9"), "n_45":("触头及导电连接异常故障-故障原因","触头接触面氧化、导电夹压接不牢、连接螺钉松动或接触面受损老化。",3,45,3,6,"#FA8C16"), "n_46":("触头及导电连接异常故障-故障现象","触头接触不稳定、连接部位发热、接触电阻增大，影响导通与开断。",4,46,1,6,"#1890FF"), "n_47":("触头及导电连接异常故障-应对措施","检查触头、导电夹、连接螺栓和连接拐臂，清洗、除氧化、紧固或更换。",3,47,3,6,"#52C41A"), "n_48":("触头及导电连接异常故障-故障后果","导通不稳定并进一步影响开断能力，导致设备损伤或停电。",4,48,1,6,"#E8684A"), "n_49":("触头及导电连接异常故障-安全风险","存在触电、电弧灼伤、高温接触部位烫伤和误送电风险。",4,49,1,6,"#722ED1"), "n_50":("误动故障","合分闸操作故障下的二级故障小类：误动故障。",2,50,3,8,"#8B5CF6"), "n_51":("误动故障-故障原因","误碰误操作、挂扣滑脱、跳闸线圈整定过低、机械累积效应、控制回路短路接地及继电保护异常等。",3,51,3,6,"#FA8C16"), "n_52":("误动故障-故障现象","在非应动条件下突然跳闸或误合闸，状态指示和保护动作与现场不一致。",4,52,1,6,"#1890FF"), "n_53":("误动故障-应对措施","核查操作记录，检查挂扣、掣子、连板及控制回路，复核灯光监视回路和保护整定，处理短路接地缺陷。",3,53,3,6,"#52C41A");
INSERT VERTEX entity(name, node_desc, lvl, source_id, degree, weight, stroke) VALUES "n_54":("误动故障-故障后果","造成非计划停电、运行方式扰动和机构磨损增加。",4,54,1,6,"#E8684A"), "n_55":("误动故障-安全风险","存在误跳、误合、误停电、触电、电弧灼伤和误试验风险。",4,55,1,6,"#722ED1"), "n_56":("拒动故障","合分闸操作故障下的二级故障小类：拒动故障。",2,56,3,8,"#8B5CF6"), "n_57":("拒动故障-故障原因","直流电源异常、控制和合分闸回路不通、线圈故障、铁心动作失灵、机构卡阻、辅助开关异常、储能异常及液压气动异常。",3,57,3,6,"#FA8C16"), "n_58":("拒动故障-故障现象","接到分闸或合闸命令后无动作、动作不到位、分合闸失败或机构被闭锁。",4,58,1,6,"#1890FF"), "n_59":("拒动故障-应对措施","检查直流电源、熔断器、控制回路、线圈、铁心和辅助开关，进行手动试验、低电压试验和机构调整，必要时停电处理。",3,59,3,6,"#52C41A"), "n_60":("拒动故障-故障后果","故障不能及时切除或送电不能及时恢复，导致事故扩大、设备过热和供电中断。",4,60,1,6,"#E8684A"), "n_61":("拒动故障-安全风险","存在带故障运行、强行操作损坏设备、触电和应急停电扩大风险。",4,61,1,6,"#722ED1"), "n_62":("机构卡阻卡涩故障","操动机构与机械传动故障下的二级故障小类：机构卡阻卡涩故障。",2,62,3,8,"#10B981"), "n_63":("机构卡阻卡涩故障-故障原因","运动部位缺油、积尘、锈蚀、污物阻塞、装配不当或部件变形。",3,63,3,6,"#FA8C16"), "n_64":("机构卡阻卡涩故障-故障现象","动作不灵活、阻力增大、传动件运动不顺畅甚至卡住。",4,64,1,6,"#1890FF"), "n_65":("机构卡阻卡涩故障-应对措施","清扫、除锈、润滑机构运动部位，检查滚子、掣子、连板和轴销，必要时调整或更换部件。",3,65,3,6,"#52C41A"), "n_66":("机构卡阻卡涩故障-故障后果","机构动作迟缓、不到位或失败，进一步引发拒动和误动。",4,66,1,6,"#E8684A"), "n_67":("机构卡阻卡涩故障-安全风险","存在机械夹伤、突然释放、误动作、触电和邻近带电作业风险。",4,67,1,6,"#722ED1"), "n_68":("操作机构死点故障","操动机构与机械传动故障下的二级故障小类：操作机构死点故障。",2,68,3,8,"#10B981"), "n_69":("操作机构死点故障-故障原因","机构几何配合失调、传动件位置调整不当、部件松动变位或传动链未复位。",3,69,3,6,"#FA8C16"), "n_70":("操作机构死点故障-故障现象","机构运行到某一位置后停止不动，不能继续完成分闸或合闸。",4,70,1,6,"#1890FF"), "n_71":("操作机构死点故障-应对措施","检查各轴、连板和传动部位是否卡住未复位，重新校正机构配合关系并进行手动试验。",3,71,3,6,"#52C41A");
INSERT VERTEX entity(name, node_desc, lvl, source_id, degree, weight, stroke) VALUES "n_72":("操作机构死点故障-故障后果","断路器停在中间状态，失去正常操作能力并增加运行风险。",4,72,1,6,"#E8684A"), "n_73":("操作机构死点故障-安全风险","存在机构反弹、机械伤害、误动作和误送电风险。",4,73,1,6,"#722ED1"), "n_74":("跳闸挂扣滑脱故障","操动机构与机械传动故障下的二级故障小类：跳闸挂扣滑脱故障。",2,74,3,8,"#10B981"), "n_75":("跳闸挂扣滑脱故障-故障原因","挂扣不牢、长期磨损、振动诱发脱扣或机构配合不良。",3,75,3,6,"#FA8C16"), "n_76":("跳闸挂扣滑脱故障-故障现象","机构挂扣保持失效，运行中脱扣并导致误跳或动作异常。",4,76,1,6,"#1890FF"), "n_77":("跳闸挂扣滑脱故障-应对措施","加强维护，重点检查掣子和连板挂扣情况，处理磨损松动并必要时调整动作电压整定值。",3,77,3,6,"#52C41A"), "n_78":("跳闸挂扣滑脱故障-故障后果","断路器误跳，造成非计划停电和机构异常磨损。",4,78,1,6,"#E8684A"), "n_79":("跳闸挂扣滑脱故障-安全风险","存在机构意外脱扣、误跳、机械伤害和试验中误动作风险。",4,79,1,6,"#722ED1"), "n_80":("合分闸铁心动作失灵故障","操动机构与机械传动故障下的二级故障小类：合分闸铁心动作失灵故障。",2,80,3,8,"#10B981"), "n_81":("合分闸铁心动作失灵故障-故障原因","套筒或铜套变形磨损、顶杆过短或松动、定位螺钉松动、铁心行程不足、油垢阻塞或机构未复位。",3,81,3,6,"#FA8C16"), "n_82":("合分闸铁心动作失灵故障-故障现象","铁心未动作、动作行程不足、动作后仍不能完成分合闸或复位不良。",4,82,1,6,"#1890FF"), "n_83":("合分闸铁心动作失灵故障-应对措施","检查铁心行程、顶杆、定位螺钉和铜套状态，必要时重新安装、调整间隙、清洗和加固。",3,83,3,6,"#52C41A"), "n_84":("合分闸铁心动作失灵故障-故障后果","断路器无法可靠完成分合闸，严重时引发线圈和机构损伤。",4,84,1,6,"#E8684A"), "n_85":("合分闸铁心动作失灵故障-安全风险","存在机构突然动作、夹伤、触电、通电试验和误操作风险。",4,85,1,6,"#722ED1"), "n_86":("储能机构不能储能故障","操动机构与机械传动故障下的二级故障小类：储能机构不能储能故障。",2,86,3,8,"#10B981"), "n_87":("储能机构不能储能故障-故障原因","储能电动机不转、微动开关异常、压紧弹簧疲劳脱落、棘爪与凸轮缺口打滑或减速箱故障。",3,87,3,6,"#FA8C16"), "n_88":("储能机构不能储能故障-故障现象","弹簧储不上能，储能机构无法进入正常待命状态。",4,88,1,6,"#1890FF"), "n_89":("储能机构不能储能故障-应对措施","检查储能电气回路、电动机、弹簧、棘爪、凸轮和减速箱，及时更换故障部件。",3,89,3,6,"#52C41A");
INSERT VERTEX entity(name, node_desc, lvl, source_id, degree, weight, stroke) VALUES "n_90":("储能机构不能储能故障-故障后果","断路器失去后续分合闸准备能力，设备可用性下降。",4,90,1,6,"#E8684A"), "n_91":("储能机构不能储能故障-安全风险","存在弹簧释放伤人、机械夹伤、误动作和电气试验触电风险。",4,91,1,6,"#722ED1"), "n_92":("分合闸后均储能故障","操动机构与机械传动故障下的二级故障小类：分合闸后均储能故障。",2,92,3,8,"#10B981"), "n_93":("分合闸后均储能故障-故障原因","合闸掣子与合闸滚子磨损超标、掣子变形或配合状态异常。",3,93,3,6,"#FA8C16"), "n_94":("分合闸后均储能故障-故障现象","分闸、合闸后均出现异常储能状态，机构逻辑紊乱。",4,94,1,6,"#1890FF"), "n_95":("分合闸后均储能故障-应对措施","检查掣子和滚子磨损及变形情况，及时更换缺陷部件并进行低电压试验。",3,95,3,6,"#52C41A"), "n_96":("分合闸后均储能故障-故障后果","机构保持和释放逻辑异常，可能引发误动作、拒动作和磨损加剧。",4,96,1,6,"#E8684A"), "n_97":("分合闸后均储能故障-安全风险","存在意外储能释放、机械伤害、误动作和试验状态误送电风险。",4,97,1,6,"#722ED1"), "n_98":("操动机构传动件变形断裂故障","操动机构与机械传动故障下的二级故障小类：操动机构传动件变形断裂故障。",2,98,3,8,"#10B981"), "n_99":("操动机构传动件变形断裂故障-故障原因","拉杆、拐臂、连板、轴销、滚子、掣子等材质不好、强度不足、受力不均或长期磨损。",3,99,3,6,"#FA8C16"), "n_100":("操动机构传动件变形断裂故障-故障现象","传动件出现弯曲、偏卡、裂纹、变形或折断，导致机构传动失常。",4,100,1,6,"#1890FF"), "n_101":("操动机构传动件变形断裂故障-应对措施","重点检查拐臂、连板、轴销和拉杆等部件，发现损伤及时更换并查明受力和装配原因。",3,101,3,6,"#52C41A"), "n_102":("操动机构传动件变形断裂故障-故障后果","传动链失效，断路器无法正常分合闸并可能停运。",4,102,1,6,"#E8684A"), "n_103":("操动机构传动件变形断裂故障-安全风险","存在部件断裂飞出、坠落、机械伤害和恢复不到位导致再次故障的风险。",4,103,1,6,"#722ED1"), "n_104":("直流操作电源异常故障","操作能源与控制回路故障下的二级故障小类：直流操作电源异常故障。",2,104,3,8,"#EF4444"), "n_105":("直流操作电源异常故障-故障原因","直流母线电压过高或过低、整流器或熔体异常、所用交流电压偏低、蓄电池组故障。",3,105,3,6,"#FA8C16"), "n_106":("直流操作电源异常故障-故障现象","控制回路供电异常、继电器和指示灯过热、分合闸动作不可靠，严重时线圈烧毁。",4,106,1,6,"#1890FF"), "n_107":("直流操作电源异常故障-应对措施","检查控制回路电压范围，必要时调节电池调节器，检查整流器、熔体、交流电压和蓄电池组状态。",3,107,3,6,"#52C41A");
INSERT VERTEX entity(name, node_desc, lvl, source_id, degree, weight, stroke) VALUES "n_108":("直流操作电源异常故障-故障后果","控制与保护动作不可靠，进一步引起误动、拒动和设备停运。",4,108,1,6,"#E8684A"), "n_109":("直流操作电源异常故障-安全风险","存在触电、短路、电弧灼伤、误操作和设备损坏风险。",4,109,1,6,"#722ED1"), "n_110":("液压机构失压故障","操作能源与控制回路故障下的二级故障小类：液压机构失压故障。",2,110,3,8,"#EF4444"), "n_111":("液压机构失压故障-故障原因","液压系统漏油、失压、油泵故障不能打油或液压机构突然失压。",3,111,3,6,"#FA8C16"), "n_112":("液压机构失压故障-故障现象","液压压力下降，机构被闭锁，无法分闸或合闸。",4,112,1,6,"#1890FF"), "n_113":("液压机构失压故障-应对措施","及时查找漏油失压原因，必要时停电处理；大修中检查液压机构分合闸阀顶针并采取隔热防寒措施。",3,113,3,6,"#52C41A"), "n_114":("液压机构失压故障-故障后果","机构被闭锁，故障切除和送电恢复能力均严重受限。",4,114,1,6,"#E8684A"), "n_115":("液压机构失压故障-安全风险","存在高压油喷出、机械伤害、触电、误动作和停电处置压力。",4,115,1,6,"#722ED1"), "n_116":("操作油风管路异常故障","操作能源与控制回路故障下的二级故障小类：操作油风管路异常故障。",2,116,3,8,"#EF4444"), "n_117":("操作油风管路异常故障-故障原因","油路或风路渗漏、堵塞、供压不稳或控制阀低温结冰。",3,117,3,6,"#FA8C16"), "n_118":("操作油风管路异常故障-故障现象","操动能源传递异常，导致断路器动作异常或拒动。",4,118,1,6,"#1890FF"), "n_119":("操作油风管路异常故障-应对措施","检查油路风路渗漏和堵塞，修复漏点，疏通故障部位，并采取保温防冻和润滑措施。",3,119,3,6,"#52C41A"), "n_120":("操作油风管路异常故障-故障后果","操动能源传递中断或不稳定，影响断路器动作可靠性。",4,120,1,6,"#E8684A"), "n_121":("操作油风管路异常故障-安全风险","存在介质喷出、压力释放、机械伤害、误动作和运行切换风险。",4,121,1,6,"#722ED1"), "n_122":("控制回路短路故障","操作能源与控制回路故障下的二级故障小类：控制回路短路故障。",2,122,3,8,"#EF4444"), "n_123":("控制回路短路故障-故障原因","红灯、绿灯或其他直流控制回路局部短路及绝缘缺陷。",3,123,3,6,"#FA8C16"), "n_124":("控制回路短路故障-故障现象","控制信号异常，可能误跳、误合，元件发热或失效。",4,124,1,6,"#1890FF"), "n_125":("控制回路短路故障-应对措施","检查红灯、绿灯和相关监视回路短路点，排查控制回路绝缘缺陷并恢复正常逻辑。",3,125,3,6,"#52C41A");
INSERT VERTEX entity(name, node_desc, lvl, source_id, degree, weight, stroke) VALUES "n_126":("控制回路短路故障-故障后果","引起误跳、误合、控制功能失效和元件烧损。",4,126,1,6,"#E8684A"), "n_127":("控制回路短路故障-安全风险","存在触电、电弧灼伤、二次回路误动作和误送电风险。",4,127,1,6,"#722ED1"), "n_128":("控制回路接地故障","操作能源与控制回路故障下的二级故障小类：控制回路接地故障。",2,128,3,8,"#EF4444"), "n_129":("控制回路接地故障-故障原因","直流回路或控制回路两点接地及相关绝缘缺陷。",3,129,3,6,"#FA8C16"), "n_130":("控制回路接地故障-故障现象","控制逻辑紊乱，误动和拒动风险增大，可检查出接地异常状态。",4,130,1,6,"#1890FF"), "n_131":("控制回路接地故障-应对措施","逐段排查接地点，修复绝缘缺陷，恢复回路完整性后再进行功能检查。",3,131,3,6,"#52C41A"), "n_132":("控制回路接地故障-故障后果","回路绝缘被破坏并导致误动、拒动或信号异常。",4,132,1,6,"#E8684A"), "n_133":("控制回路接地故障-安全风险","存在触电、误动作、逻辑异常扩大和恢复操作不当风险。",4,133,1,6,"#722ED1"), "n_134":("合分闸控制回路故障","操作能源与控制回路故障下的二级故障小类：合分闸控制回路故障。",2,134,3,8,"#EF4444"), "n_135":("合分闸控制回路故障-故障原因","接触器失压或欠压、线圈断线、接点接触不良、连接线断线或辅助接点未闭合。",3,135,3,6,"#FA8C16"), "n_136":("合分闸控制回路故障-故障现象","控制回路不通，控制命令无法可靠传递，断路器不能正常分合闸。",4,136,1,6,"#1890FF"), "n_137":("合分闸控制回路故障-应对措施","采用电压法、电位法、电阻法检查回路导通情况，处理接触器、接点和连接线问题。",3,137,3,6,"#52C41A"), "n_138":("合分闸控制回路故障-故障后果","控制命令无法送达执行部件，影响事故处理和送电恢复。",4,138,1,6,"#E8684A"), "n_139":("合分闸控制回路故障-安全风险","存在误合、误分、触电、电弧灼伤和控制链恢复错误风险。",4,139,1,6,"#722ED1"), "n_140":("合分闸线圈故障","操作能源与控制回路故障下的二级故障小类：合分闸线圈故障。",2,140,3,8,"#EF4444"), "n_141":("合分闸线圈故障-故障原因","合分闸线圈失压、欠电压、断线、匝间短路、绝缘损坏或烧毁。",3,141,3,6,"#FA8C16"), "n_142":("合分闸线圈故障-故障现象","线圈过热、烧毁或动作无力，分闸或合闸命令无法可靠执行。",4,142,1,6,"#1890FF"), "n_143":("合分闸线圈故障-应对措施","检查线圈直阻、绝缘和动作电压，控制熔断器额定电流，避免频繁操作，并在检修后做必要试验。",3,143,3,6,"#52C41A");
INSERT VERTEX entity(name, node_desc, lvl, source_id, degree, weight, stroke) VALUES "n_144":("合分闸线圈故障-故障后果","断路器动作驱动力不足或完全丧失，导致拒动和设备损伤。",4,144,1,6,"#E8684A"), "n_145":("合分闸线圈故障-安全风险","存在通电试验过热烧毁、触电、电弧灼伤和机构误动作风险。",4,145,1,6,"#722ED1"), "n_146":("辅助开关及转换接点异常故障","操作能源与控制回路故障下的二级故障小类：辅助开关及转换接点异常故障。",2,146,3,8,"#EF4444"), "n_147":("辅助开关及转换接点异常故障-故障原因","辅助开关安装不牢、接点切换不灵活、接触不良、转换接点生锈或受潮氧化。",3,147,3,6,"#FA8C16"), "n_148":("辅助开关及转换接点异常故障-故障现象","状态指示错误、联锁信号异常、转换接点失灵。",4,148,1,6,"#1890FF"), "n_149":("辅助开关及转换接点异常故障-应对措施","保证安装牢固，检查接点转换和接触状态，及时处理松动、锈蚀、氧化、受潮和凝露问题。",3,149,3,6,"#52C41A"), "n_150":("辅助开关及转换接点异常故障-故障后果","造成误指示、误联锁、误操作、拒动或动作逻辑错误。",4,150,1,6,"#E8684A"), "n_151":("辅助开关及转换接点异常故障-安全风险","存在误指示、误联锁、误操作、触电和试验恢复后逻辑异常风险。",4,151,1,6,"#722ED1"), "n_152":("继电保护误动作故障","继电保护与测量二次回路故障下的二级故障小类：继电保护误动作故障。",2,152,3,8,"#6366F1"), "n_153":("继电保护误动作故障-故障原因","保护装置本身质量问题、振动温度灰尘腐蚀、电源波动或脉冲干扰等。",3,153,3,6,"#FA8C16"), "n_154":("继电保护误动作故障-故障现象","保护在非故障状态下误启动并误发跳闸信号。",4,154,1,6,"#1890FF"), "n_155":("继电保护误动作故障-应对措施","检查保护工作环境、直流电源稳定性和抗干扰情况，排查装置内部及外部影响因素。",3,155,3,6,"#52C41A"), "n_156":("继电保护误动作故障-故障后果","造成非计划跳闸、停电和运行方式扰动。",4,156,1,6,"#E8684A"), "n_157":("继电保护误动作故障-安全风险","存在误发跳闸、误试验、误整定和误操作风险。",4,157,1,6,"#722ED1"), "n_158":("保护整定不当故障","继电保护与测量二次回路故障下的二级故障小类：保护整定不当故障。",2,158,3,8,"#6366F1"), "n_159":("保护整定不当故障-故障原因","整定值设置不合理、动作门槛与现场运行条件不匹配或检修后未正确复核。",3,159,3,6,"#FA8C16"), "n_160":("保护整定不当故障-故障现象","保护动作提前、滞后、误动或拒动，行为不符合现场要求。",4,160,1,6,"#1890FF"), "n_161":("保护整定不当故障-应对措施","重新复核整定值，使其与运行方式和设备特性匹配，并进行动作试验验证。",3,161,3,6,"#52C41A");
INSERT VERTEX entity(name, node_desc, lvl, source_id, degree, weight, stroke) VALUES "n_162":("保护整定不当故障-故障后果","保护选择性和灵敏性下降，可能动作越级或故障切除不及时。",4,162,1,6,"#E8684A"), "n_163":("保护整定不当故障-安全风险","存在误动、拒动、误修改、误投退和电气试验风险。",4,163,1,6,"#722ED1"), "n_164":("互感器回路故障","继电保护与测量二次回路故障下的二级故障小类：互感器回路故障。",2,164,3,8,"#6366F1"), "n_165":("互感器回路故障-故障原因","互感器及其二次回路接线异常、接触不良、绝缘缺陷或回路故障。",3,165,3,6,"#FA8C16"), "n_166":("互感器回路故障-故障现象","保护和测量输入异常、采样失真、控制判断偏差。",4,166,1,6,"#1890FF"), "n_167":("互感器回路故障-应对措施","检查互感器及二次回路接线、接触和绝缘状态，排除断线和接线异常。",3,167,3,6,"#52C41A"), "n_168":("互感器回路故障-故障后果","保护判断错误，误动和拒动风险上升。",4,168,1,6,"#E8684A"), "n_169":("互感器回路故障-安全风险","存在误接线、误判断、二次开路或短路风险。",4,169,1,6,"#722ED1"), "n_170":("保护出口回路接地故障","继电保护与测量二次回路故障下的二级故障小类：保护出口回路接地故障。",2,170,3,8,"#6366F1"), "n_171":("保护出口回路接地故障-故障原因","保护出口继电器线圈正电源侧接地或相关出口回路接地缺陷。",3,171,3,6,"#FA8C16"), "n_172":("保护出口回路接地故障-故障现象","保护出口信号异常，可能误发动作命令或出口失控。",4,172,1,6,"#1890FF"), "n_173":("保护出口回路接地故障-应对措施","检查出口继电器线圈正电源侧和相关出口回路接地情况，消除缺陷后重新核验逻辑。",3,173,3,6,"#52C41A"), "n_174":("保护出口回路接地故障-故障后果","可能误发跳闸命令或导致出口回路失效，影响故障切除。",4,174,1,6,"#E8684A"), "n_175":("保护出口回路接地故障-安全风险","存在误跳、误信号、触电和出口逻辑恢复不当风险。",4,175,1,6,"#722ED1"), "n_176":("寄生回路故障","继电保护与测量二次回路故障下的二级故障小类：寄生回路故障。",2,176,3,8,"#6366F1"), "n_177":("寄生回路故障-故障原因","二次系统中存在非设计预期的隐蔽通路或串扰回路。",3,177,3,6,"#FA8C16"), "n_178":("寄生回路故障-故障现象","控制与保护逻辑异常串扰、非预期联动和误信号。",4,178,1,6,"#1890FF"), "n_179":("寄生回路故障-应对措施","梳理二次系统回路关系，查明并消除寄生通路，恢复逻辑独立性。",3,179,3,6,"#52C41A");
INSERT VERTEX entity(name, node_desc, lvl, source_id, degree, weight, stroke) VALUES "n_180":("寄生回路故障-故障后果","引发误动、逻辑混乱和运行异常。",4,180,1,6,"#E8684A"), "n_181":("寄生回路故障-安全风险","存在误判断、误隔离、误动作和串扰继续扩大的风险。",4,181,1,6,"#722ED1"), "n_182":("绝缘不良故障","本体绝缘与支撑结构故障下的二级故障小类：绝缘不良故障。",2,182,3,8,"#14B8A6"), "n_183":("绝缘不良故障-故障原因","绝缘部件受潮、老化、污染、损伤或绝缘水平下降。",3,183,3,6,"#FA8C16"), "n_184":("绝缘不良故障-故障现象","绝缘性能变差，出现放电、闪络和绝缘事故隐患。",4,184,1,6,"#1890FF"), "n_185":("绝缘不良故障-应对措施","加强绝缘检查、清扫、干燥和状态检修，必要时更换绝缘部件。",3,185,3,6,"#52C41A"), "n_186":("绝缘不良故障-故障后果","放电、闪络和绝缘事故风险增大，严重时停电和设备损坏。",4,186,1,6,"#E8684A"), "n_187":("绝缘不良故障-安全风险","存在触电、闪络、电弧灼伤和误接近带电部位风险。",4,187,1,6,"#722ED1"), "n_188":("瓷件损伤故障","本体绝缘与支撑结构故障下的二级故障小类：瓷件损伤故障。",2,188,3,8,"#14B8A6"), "n_189":("瓷件损伤故障-故障原因","安装受力不均、机械冲击、长期应力作用或检修不当。",3,189,3,6,"#FA8C16"), "n_190":("瓷件损伤故障-故障现象","瓷件出现裂纹、破损、缺口甚至断裂。",4,190,1,6,"#1890FF"), "n_191":("瓷件损伤故障-应对措施","保证安装受力均匀，发现损伤及时更换，避免用力过猛和不当装配。",3,191,3,6,"#52C41A"), "n_192":("瓷件损伤故障-故障后果","绝缘能力和支撑能力下降，可能引起闪络和停运。",4,192,1,6,"#E8684A"), "n_193":("瓷件损伤故障-安全风险","存在瓷件碎裂飞溅、坠落、机械伤害和触电风险。",4,193,1,6,"#722ED1"), "n_194":("本体连接件松动断裂故障","本体绝缘与支撑结构故障下的二级故障小类：本体连接件松动断裂故障。",2,194,3,8,"#14B8A6"), "n_195":("本体连接件松动断裂故障-故障原因","连接件长期受力、紧固不当、松动失修、材质缺陷或疲劳损伤。",3,195,3,6,"#FA8C16"), "n_196":("本体连接件松动断裂故障-故障现象","本体连接件松动、位移、变形或断裂，伴随振动和异响。",4,196,1,6,"#1890FF"), "n_197":("本体连接件松动断裂故障-应对措施","定期检查拐臂、联板、轴销和紧固部位，发现松动和裂纹及时更换并重新紧固。",3,197,3,6,"#52C41A");
INSERT VERTEX entity(name, node_desc, lvl, source_id, degree, weight, stroke) VALUES "n_198":("本体连接件松动断裂故障-故障后果","本体结构稳定性下降，严重时部件脱落、损坏扩大或停电。",4,198,1,6,"#E8684A"), "n_199":("本体连接件松动断裂故障-安全风险","存在结构失稳、部件脱落、机械伤害和误送电风险。",4,199,1,6,"#722ED1"), "n_200":("绝缘拉杆拉脱故障","本体绝缘与支撑结构故障下的二级故障小类：绝缘拉杆拉脱故障。",2,200,3,8,"#14B8A6"), "n_201":("绝缘拉杆拉脱故障-故障原因","绝缘拉杆安装不正确、连接固定不可靠、长期受力松动或配合部位损伤。",3,201,3,6,"#FA8C16"), "n_202":("绝缘拉杆拉脱故障-故障现象","绝缘拉杆松脱、脱出，操作传动和绝缘联接同时受损。",4,202,1,6,"#1890FF"), "n_203":("绝缘拉杆拉脱故障-应对措施","检查安装与固定状态，发现风险及时校正、加固或更换。",3,203,3,6,"#52C41A"), "n_204":("绝缘拉杆拉脱故障-故障后果","操作传动中断且绝缘联接失效，断路器无法正常动作。",4,204,1,6,"#E8684A"), "n_205":("绝缘拉杆拉脱故障-安全风险","存在传动失控、机械伤害、触电和恢复不牢风险。",4,205,1,6,"#722ED1"), "n_206":("基础支架失稳故障","本体绝缘与支撑结构故障下的二级故障小类：基础支架失稳故障。",2,206,3,8,"#14B8A6"), "n_207":("基础支架失稳故障-故障原因","基础支架不牢固、结构件安装质量不足、连接松动或长期运行后刚度下降。",3,207,3,6,"#FA8C16"), "n_208":("基础支架失稳故障-故障现象","支架松动、晃动、位置偏移或整体稳定性下降。",4,208,1,6,"#1890FF"), "n_209":("基础支架失稳故障-应对措施","检查基础支架牢固程度和稳定性，对松动和刚度不足部位及时加固、调整或修复。",3,209,3,6,"#52C41A"), "n_210":("基础支架失稳故障-故障后果","断路器本体支撑不牢，严重时影响整体结构安全并导致停运。",4,210,1,6,"#E8684A"), "n_211":("基础支架失稳故障-安全风险","存在设备倾斜、部件坠落、机械伤害和整体结构安全风险。",4,211,1,6,"#722ED1"), "n_212":("油断路器缺油故障-应急资源","主要需要绝缘防护用品、停电检修票证、补油设备、漏油点处理工具、备用绝缘油、油位检测工具和现场检修人员。",4,212,1,6,"#13C2C2"), "n_213":("空气断路器气压降低故障-应急资源","主要需要压力检测仪表、供气或补压设备、气路检漏工具、绝缘防护用品、现场值检人员和停电检修条件。",4,213,1,6,"#13C2C2"), "n_214":("六氟化硫介质泄漏故障-应急资源","主要需要检漏仪、补气和回收装置、通风设备、防毒面具、防护服、手套、气体处理人员和停电检修条件。",4,214,1,6,"#13C2C2"), "n_215":("灭弧室烧损爆炸故障-应急资源","主要需要事故隔离和消防装备、备用断路器或灭弧室组件、短路电流核算资料、抢修工器具、起吊设备和应急检修人员。",4,215,1,6,"#13C2C2");
INSERT VERTEX entity(name, node_desc, lvl, source_id, degree, weight, stroke) VALUES "n_216":("断路故障-应急资源","主要需要连续性检测工具、绝缘防护用品、备用导电连接件、紧固工器具、停电作业条件和检修人员。",4,216,1,6,"#13C2C2"), "n_217":("导电回路直阻超标故障-应急资源","主要需要回路电阻测试仪、接触面清理工具、备用导电夹和螺栓、紧固工器具、红外测温或发热检测手段以及检修人员。",4,217,1,6,"#13C2C2"), "n_218":("触头及导电连接异常故障-应急资源","主要需要触头检修工具、备用触头和导电夹、紧固工器具、接触面处理材料、绝缘防护用品和现场检修人员。",4,218,1,6,"#13C2C2"), "n_219":("误动故障-应急资源","主要需要操作记录、二次回路图纸、保护试验装置、绝缘测试工具、灯光监视回路备件、专业继保人员和运行值班人员。",4,219,1,6,"#13C2C2"), "n_220":("拒动故障-应急资源","主要需要低电压试验电源、万用表和绝缘表、备用线圈和接触器、机构调整工器具、手动操作工具、检修票证和检修人员。",4,220,1,6,"#13C2C2"), "n_221":("机构卡阻卡涩故障-应急资源","主要需要清扫除锈材料、润滑油脂、拆装工器具、备用滚子掣子连板轴销、手动操作工具和机构检修人员。",4,221,1,6,"#13C2C2"), "n_222":("操作机构死点故障-应急资源","主要需要机构调整工器具、手动试验装置、定位和测量工具、备用传动部件、技术资料和检修人员。",4,222,1,6,"#13C2C2"), "n_223":("跳闸挂扣滑脱故障-应急资源","主要需要挂扣和掣子类备件、测量和调整工具、紧固工器具、检修图纸资料和有经验的机构维护人员。",4,223,1,6,"#13C2C2"), "n_224":("合分闸铁心动作失灵故障-应急资源","主要需要线圈和铁心检测工具、清洗材料、备用顶杆和紧固件、间隙调整工具、低电压试验条件和检修人员。",4,224,1,6,"#13C2C2"), "n_225":("储能机构不能储能故障-应急资源","主要需要微动开关检测工具、电机测试工具、备用弹簧、棘爪、减速箱部件、手动摇把和机构检修人员。",4,225,1,6,"#13C2C2"), "n_226":("分合闸后均储能故障-应急资源","主要需要掣子和滚子类备件、低电压试验装置、机构逻辑校验资料、拆装工器具和检修人员。",4,226,1,6,"#13C2C2"), "n_227":("操动机构传动件变形断裂故障-应急资源","主要需要备用拉杆、拐臂、连板、轴销等传动件，配套拆装和紧固工器具、起吊辅助工具和检修人员。",4,227,1,6,"#13C2C2"), "n_228":("直流操作电源异常故障-应急资源","主要需要直流电压测量工具、蓄电池维护设备、备用熔体、整流器检修备件、绝缘防护用品和电气检修人员。",4,228,1,6,"#13C2C2"), "n_229":("液压机构失压故障-应急资源","主要需要压力表、油泵或液压处理设备、密封件和油液、绝缘防护用品、停电检修条件和液压维护人员。",4,229,1,6,"#13C2C2"), "n_230":("操作油风管路异常故障-应急资源","主要需要油路风路检修工具、备用阀件和管件、密封材料、供压设备、保温防冻材料和检修人员。",4,230,1,6,"#13C2C2"), "n_231":("控制回路短路故障-应急资源","主要需要回路图纸、绝缘测试工具、万用表、备用灯泡和导线、熔体、二次回路检修人员和停电作业条件。",4,231,1,6,"#13C2C2"), "n_232":("控制回路接地故障-应急资源","主要需要绝缘表、接地故障排查工具、回路图纸、绝缘恢复材料、检修票证和二次回路检修人员。",4,232,1,6,"#13C2C2"), "n_233":("合分闸控制回路故障-应急资源","主要需要电压法、电位法、电阻法测试工具、备用接触器和接点备件、回路图纸、手动试验条件和检修人员。",4,233,1,6,"#13C2C2");
INSERT VERTEX entity(name, node_desc, lvl, source_id, degree, weight, stroke) VALUES "n_234":("合分闸线圈故障-应急资源","主要需要线圈直阻测试工具、备用线圈、熔断器备件、绝缘测试工具、低电压试验条件和检修人员。",4,234,1,6,"#13C2C2"), "n_235":("辅助开关及转换接点异常故障-应急资源","主要需要辅助开关和接点类备件、清洁除锈材料、调整工器具、回路图纸和二次检修人员。",4,235,1,6,"#13C2C2"), "n_236":("继电保护误动作故障-应急资源","主要需要继电保护试验装置、二次回路图纸、整定单、计算机和调试软件、专业继保人员及运行配合条件。",4,236,1,6,"#13C2C2"), "n_237":("保护整定不当故障-应急资源","主要需要整定计算资料、试验装置、定值单、保护调试工具、继保专业人员和运行方式资料。",4,237,1,6,"#13C2C2"), "n_238":("互感器回路故障-应急资源","主要需要互感器二次回路图纸、测试仪表、备用端子和连接件、绝缘测试工具以及二次检修人员。",4,238,1,6,"#13C2C2"), "n_239":("保护出口回路接地故障-应急资源","主要需要绝缘测试工具、回路图纸、出口继电器相关备件、试验装置和继保检修人员。",4,239,1,6,"#13C2C2"), "n_240":("寄生回路故障-应急资源","主要需要完整的二次回路图纸、逻辑排查工具、继保试验装置、经验丰富的二次专业人员和运行配合条件。",4,240,1,6,"#13C2C2"), "n_241":("绝缘不良故障-应急资源","主要需要绝缘测试工具、清扫和干燥设备、备用绝缘件、绝缘防护用品和检修人员。",4,241,1,6,"#13C2C2"), "n_242":("瓷件损伤故障-应急资源","主要需要备用瓷件、吊装和安装工器具、绝缘防护用品、停电作业条件和检修人员。",4,242,1,6,"#13C2C2"), "n_243":("本体连接件松动断裂故障-应急资源","主要需要备用连接件、紧固工器具、结构检查工具、起吊辅助设备和检修人员。",4,243,1,6,"#13C2C2"), "n_244":("绝缘拉杆拉脱故障-应急资源","主要需要备用绝缘拉杆、安装和校正工器具、绝缘测试工具、停电作业条件和检修人员。",4,244,1,6,"#13C2C2"), "n_245":("基础支架失稳故障-应急资源","主要需要支架加固材料、紧固和测量工器具、必要的起吊支撑设备、结构检查手段和检修人员。",4,245,1,6,"#13C2C2");

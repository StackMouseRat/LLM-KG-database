MATCH (v:entity) RETURN count(v) AS node_count;
MATCH ()-[e:rel]->() RETURN count(e) AS edge_count;
MATCH (v:entity) WHERE v.entity.lvl == 1 RETURN v.entity.source_id AS source_id, v.entity.name AS name, substr(v.entity.node_desc,0,80) AS desc_preview ORDER BY source_id;
DROP SPACE IF EXISTS llmkg_test;
CREATE SPACE IF NOT EXISTS llmkg_test(partition_num=10, replica_factor=1, vid_type=FIXED_STRING(128));
USE llmkg_test;
CREATE TAG IF NOT EXISTS entity(name string, node_desc string, degree int, weight int, stroke string, lvl int, source_id int);
CREATE EDGE IF NOT EXISTS rel(relation string, from_name string, to_name string);
INSERT VERTEX entity(name, node_desc, degree, weight, stroke, lvl, source_id) VALUES "n_0":("高压断路器","依据第一至第七层级汇总稿形成的高压断路器故障知识图谱实体。",7,10,"#9A3412",0,0), "n_1":("灭弧与介质状态故障","高压断路器故障一级大类：灭弧与介质状态故障。",5,9,"#D97706",1,1), "n_2":("导电回路与开断故障","高压断路器故障一级大类：导电回路与开断故障。",4,9,"#0EA5E9",1,2), "n_8":("油断路器缺油故障","灭弧与介质状态故障下的二级故障小类：油断路器缺油故障。",3,8,"#D97706",2,8), "n_9":("油断路器缺油故障-故障原因","灭弧室或油路漏油、渗油，导致油位持续下降并严重缺油。",3,6,"#FA8C16",3,9), "n_10":("油断路器缺油故障-故障现象","油位计中看不见油面，伴随明显漏油，断路器开断安全性下降。",1,6,"#1890FF",4,10), "n_11":("油断路器缺油故障-应对措施","查明漏油部位，必要时停运处理，采取可靠安全措施补油和检修，严禁严重缺油运行。",3,6,"#52C41A",3,11), "n_12":("油断路器缺油故障-故障后果","灭弧和开断能力下降，可能导致设备损坏、停运和事故扩大。",1,6,"#E8684A",4,12), "n_13":("油断路器缺油故障-安全风险","处置中存在触电、电弧灼伤、油介质着火和误操作停电风险。",1,6,"#722ED1",4,13), "n_14":("空气断路器气压降低故障","灭弧与介质状态故障下的二级故障小类：空气断路器气压降低故障。",3,8,"#D97706",2,14), "n_15":("空气断路器气压降低故障-故障原因","运行气压低于最小允许值，可能与供气不足、气路泄漏或相关部件异常有关。",3,6,"#FA8C16",3,15), "n_16":("空气断路器气压降低故障-故障现象","压力信号触发，操作回路被切断或重合闸被闭锁，断路器运行能力下降。",1,6,"#1890FF",4,16), "n_17":("空气断路器气压降低故障-应对措施","迅速检查压力下降原因，利用气压降低接点切断操作回路或停止重合闸，必要时停运处理。",3,6,"#52C41A",3,17), "n_18":("空气断路器气压降低故障-故障后果","断路器无法可靠执行分合闸操作，影响供电可靠性和故障处置能力。",1,6,"#E8684A",4,18), "n_19":("空气断路器气压降低故障-安全风险","存在带压系统突然释放、误动作、触电和停电切换风险。",1,6,"#722ED1",4,19), "n_20":("六氟化硫介质泄漏故障","灭弧与介质状态故障下的二级故障小类：六氟化硫介质泄漏故障。",3,8,"#D97706",2,20), "n_21":("六氟化硫介质泄漏故障-故障原因","气室、密封部位或连接部位漏气，导致气体压力下降并触发报警。",3,6,"#FA8C16",3,21), "n_22":("六氟化硫介质泄漏故障-故障现象","表压下降、漏气报警、可检出漏点，严重时大量漏气并伴随气体外逸。",1,6,"#1890FF",4,22), "n_23":("六氟化硫介质泄漏故障-应对措施","检查压力表，使用检漏仪查找漏点并补气；大量漏气时停电处理并加强现场防护和通风。",3,6,"#52C41A",3,23), "n_24":("六氟化硫介质泄漏故障-故障后果","绝缘和灭弧性能下降，断路器被迫停运或限运，并带来人员暴露风险。",1,6,"#E8684A",4,24), "n_25":("六氟化硫介质泄漏故障-安全风险","存在有害气体暴露、缺氧、触电、电弧灼伤和防护不到位风险。",1,6,"#722ED1",4,25), "n_26":("灭弧室烧损爆炸故障","灭弧与介质状态故障下的二级故障小类：灭弧室烧损爆炸故障。",3,8,"#D97706",2,26), "n_27":("灭弧室烧损爆炸故障-故障原因","短路电流超过开断能力、系统短路电流控制不当、灭弧室油位过低或缺油、开断故障后喷油严重未及时处理。",3,6,"#FA8C16",3,27), "n_28":("灭弧室烧损爆炸故障-故障现象","灭弧室烧损、喷油严重、绝缘和灭弧性能急剧下降，严重时爆炸。",1,6,"#1890FF",4,28), "n_29":("灭弧室烧损爆炸故障-应对措施","定期核算短路电流，采取限流与保护优化措施，对能力不足设备及时调换升级，并加强油位监视和状态检修。",3,6,"#52C41A",3,29), "n_30":("灭弧室烧损爆炸故障-故障后果","设备严重损坏甚至报废，停电范围扩大，并伴随事故升级风险。",1,6,"#E8684A",4,30), "n_31":("灭弧室烧损爆炸故障-安全风险","存在爆炸、飞溅、火灾、电弧灼伤和人身伤害风险。",1,6,"#722ED1",4,31), "n_32":("断路故障","导电回路与开断故障下的二级故障小类：断路故障。",3,8,"#0EA5E9",2,32), "n_33":("断路故障-故障原因","连接件、触头、导电夹等导电部位接触失效、松动断裂或材质强度不足。",3,6,"#FA8C16",3,33), "n_34":("断路故障-故障现象","电流通路中断，设备无法正常送电或运行中突然失去导通能力。",1,6,"#1890FF",4,34), "n_35":("断路故障-应对措施","检查断点、连接件和触头状态，对失效和损伤部件及时更换和紧固。",3,6,"#52C41A",3,35), "n_36":("断路故障-故障后果","直接造成停电、运行中断或设备功能失效。",1,6,"#E8684A",4,36), "n_37":("断路故障-安全风险","排查断点和恢复送电过程中存在误送电、触电和电弧灼伤风险。",1,6,"#722ED1",4,37), "n_38":("导电回路直阻超标故障","导电回路与开断故障下的二级故障小类：导电回路直阻超标故障。",3,8,"#0EA5E9",2,38), "n_39":("导电回路直阻超标故障-故障原因","接触面氧化、固定螺钉松动、接触压力不足或接触不良。",3,6,"#FA8C16",3,39), "n_40":("导电回路直阻超标故障-故障现象","导电回路直阻测量值超标，接触部位发热增加。",1,6,"#1890FF",4,40), "n_41":("导电回路直阻超标故障-应对措施","检查真空泡上部接触面和导电夹固定螺钉，必要时除氧化、紧固并复测。",3,6,"#52C41A",3,41), "n_42":("导电回路直阻超标故障-故障后果","接触发热加剧，长期会加速触头损伤，严重时设备烧损停运。",1,6,"#E8684A",4,42), "n_43":("导电回路直阻超标故障-安全风险","存在烫伤、触电、电弧灼伤和恢复不当后二次过热风险。",1,6,"#722ED1",4,43), "n_44":("触头及导电连接异常故障","导电回路与开断故障下的二级故障小类：触头及导电连接异常故障。",3,8,"#0EA5E9",2,44), "n_45":("触头及导电连接异常故障-故障原因","触头接触面氧化、导电夹压接不牢、连接螺钉松动或接触面受损老化。",3,6,"#FA8C16",3,45), "n_46":("触头及导电连接异常故障-故障现象","触头接触不稳定、连接部位发热、接触电阻增大，影响导通与开断。",1,6,"#1890FF",4,46), "n_47":("触头及导电连接异常故障-应对措施","检查触头、导电夹、连接螺栓和连接拐臂，清洗、除氧化、紧固或更换。",3,6,"#52C41A",3,47), "n_48":("触头及导电连接异常故障-故障后果","导通不稳定并进一步影响开断能力，导致设备损伤或停电。",1,6,"#E8684A",4,48), "n_49":("触头及导电连接异常故障-安全风险","存在触电、电弧灼伤、高温接触部位烫伤和误送电风险。",1,6,"#722ED1",4,49), "n_212":("油断路器缺油故障-应急资源","主要需要绝缘防护用品、停电检修票证、补油设备、漏油点处理工具、备用绝缘油、油位检测工具和现场检修人员。",1,6,"#13C2C2",4,212), "n_213":("空气断路器气压降低故障-应急资源","主要需要压力检测仪表、供气或补压设备、气路检漏工具、绝缘防护用品、现场值检人员和停电检修条件。",1,6,"#13C2C2",4,213), "n_214":("六氟化硫介质泄漏故障-应急资源","主要需要检漏仪、补气和回收装置、通风设备、防毒面具、防护服、手套、气体处理人员和停电检修条件。",1,6,"#13C2C2",4,214), "n_215":("灭弧室烧损爆炸故障-应急资源","主要需要事故隔离和消防装备、备用断路器或灭弧室组件、短路电流核算资料、抢修工器具、起吊设备和应急检修人员。",1,6,"#13C2C2",4,215), "n_216":("断路故障-应急资源","主要需要连续性检测工具、绝缘防护用品、备用导电连接件、紧固工器具、停电作业条件和检修人员。",1,6,"#13C2C2",4,216), "n_217":("导电回路直阻超标故障-应急资源","主要需要回路电阻测试仪、接触面清理工具、备用导电夹和螺栓、紧固工器具、红外测温或发热检测手段以及检修人员。",1,6,"#13C2C2",4,217), "n_218":("触头及导电连接异常故障-应急资源","主要需要触头检修工具、备用触头和导电夹、紧固工器具、接触面处理材料、绝缘防护用品和现场检修人员。",1,6,"#13C2C2",4,218);
INSERT EDGE rel(relation, from_name, to_name) VALUES "n_0"->"n_1":("发生","高压断路器","灭弧与介质状态故障"), "n_0"->"n_2":("发生","高压断路器","导电回路与开断故障"), "n_1"->"n_8":("包含","灭弧与介质状态故障","油断路器缺油故障"), "n_8"->"n_9":("起因于","油断路器缺油故障","油断路器缺油故障-故障原因"), "n_9"->"n_10":("表现","油断路器缺油故障-故障原因","油断路器缺油故障-故障现象"), "n_8"->"n_11":("处置","油断路器缺油故障","油断路器缺油故障-应对措施"), "n_9"->"n_12":("导致","油断路器缺油故障-故障原因","油断路器缺油故障-故障后果"), "n_11"->"n_13":("存在","油断路器缺油故障-应对措施","油断路器缺油故障-安全风险"), "n_1"->"n_14":("包含","灭弧与介质状态故障","空气断路器气压降低故障"), "n_14"->"n_15":("起因于","空气断路器气压降低故障","空气断路器气压降低故障-故障原因"), "n_15"->"n_16":("表现","空气断路器气压降低故障-故障原因","空气断路器气压降低故障-故障现象"), "n_14"->"n_17":("处置","空气断路器气压降低故障","空气断路器气压降低故障-应对措施"), "n_15"->"n_18":("导致","空气断路器气压降低故障-故障原因","空气断路器气压降低故障-故障后果"), "n_17"->"n_19":("存在","空气断路器气压降低故障-应对措施","空气断路器气压降低故障-安全风险"), "n_1"->"n_20":("包含","灭弧与介质状态故障","六氟化硫介质泄漏故障"), "n_20"->"n_21":("起因于","六氟化硫介质泄漏故障","六氟化硫介质泄漏故障-故障原因"), "n_21"->"n_22":("表现","六氟化硫介质泄漏故障-故障原因","六氟化硫介质泄漏故障-故障现象"), "n_20"->"n_23":("处置","六氟化硫介质泄漏故障","六氟化硫介质泄漏故障-应对措施"), "n_21"->"n_24":("导致","六氟化硫介质泄漏故障-故障原因","六氟化硫介质泄漏故障-故障后果"), "n_23"->"n_25":("存在","六氟化硫介质泄漏故障-应对措施","六氟化硫介质泄漏故障-安全风险"), "n_1"->"n_26":("包含","灭弧与介质状态故障","灭弧室烧损爆炸故障"), "n_26"->"n_27":("起因于","灭弧室烧损爆炸故障","灭弧室烧损爆炸故障-故障原因"), "n_27"->"n_28":("表现","灭弧室烧损爆炸故障-故障原因","灭弧室烧损爆炸故障-故障现象"), "n_26"->"n_29":("处置","灭弧室烧损爆炸故障","灭弧室烧损爆炸故障-应对措施"), "n_27"->"n_30":("导致","灭弧室烧损爆炸故障-故障原因","灭弧室烧损爆炸故障-故障后果"), "n_29"->"n_31":("存在","灭弧室烧损爆炸故障-应对措施","灭弧室烧损爆炸故障-安全风险"), "n_2"->"n_32":("包含","导电回路与开断故障","断路故障"), "n_32"->"n_33":("起因于","断路故障","断路故障-故障原因"), "n_33"->"n_34":("表现","断路故障-故障原因","断路故障-故障现象"), "n_32"->"n_35":("处置","断路故障","断路故障-应对措施"), "n_33"->"n_36":("导致","断路故障-故障原因","断路故障-故障后果"), "n_35"->"n_37":("存在","断路故障-应对措施","断路故障-安全风险"), "n_2"->"n_38":("包含","导电回路与开断故障","导电回路直阻超标故障"), "n_38"->"n_39":("起因于","导电回路直阻超标故障","导电回路直阻超标故障-故障原因"), "n_39"->"n_40":("表现","导电回路直阻超标故障-故障原因","导电回路直阻超标故障-故障现象"), "n_38"->"n_41":("处置","导电回路直阻超标故障","导电回路直阻超标故障-应对措施"), "n_39"->"n_42":("导致","导电回路直阻超标故障-故障原因","导电回路直阻超标故障-故障后果"), "n_41"->"n_43":("存在","导电回路直阻超标故障-应对措施","导电回路直阻超标故障-安全风险"), "n_2"->"n_44":("包含","导电回路与开断故障","触头及导电连接异常故障"), "n_44"->"n_45":("起因于","触头及导电连接异常故障","触头及导电连接异常故障-故障原因"), "n_45"->"n_46":("表现","触头及导电连接异常故障-故障原因","触头及导电连接异常故障-故障现象"), "n_44"->"n_47":("处置","触头及导电连接异常故障","触头及导电连接异常故障-应对措施"), "n_45"->"n_48":("导致","触头及导电连接异常故障-故障原因","触头及导电连接异常故障-故障后果"), "n_47"->"n_49":("存在","触头及导电连接异常故障-应对措施","触头及导电连接异常故障-安全风险"), "n_11"->"n_212":("需要","油断路器缺油故障-应对措施","油断路器缺油故障-应急资源"), "n_17"->"n_213":("需要","空气断路器气压降低故障-应对措施","空气断路器气压降低故障-应急资源"), "n_23"->"n_214":("需要","六氟化硫介质泄漏故障-应对措施","六氟化硫介质泄漏故障-应急资源"), "n_29"->"n_215":("需要","灭弧室烧损爆炸故障-应对措施","灭弧室烧损爆炸故障-应急资源"), "n_35"->"n_216":("需要","断路故障-应对措施","断路故障-应急资源"), "n_41"->"n_217":("需要","导电回路直阻超标故障-应对措施","导电回路直阻超标故障-应急资源"), "n_47"->"n_218":("需要","触头及导电连接异常故障-应对措施","触头及导电连接异常故障-应急资源");
FETCH PROP ON entity "n_1", "n_2" YIELD properties(vertex).name AS name, properties(vertex).lvl AS lvl, properties(vertex).source_id AS source_id;
GO FROM "n_0" OVER rel YIELD dst(edge) AS child, rel.relation AS relation, rel.to_name AS to_name;
MATCH (v:entity) RETURN count(v) AS node_count;
MATCH ()-[e:rel]->() RETURN count(e) AS edge_count;